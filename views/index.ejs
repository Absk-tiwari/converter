            border-bottom-right-radius:14px;
        }
        .table-rows tr {
            gap: 20px;
        }
        .table td, .table th {
            border-top: none!important;
        }
        .doc_banner_area {
            background: #537395;
        }
    </style>

    <title> Love 2 converter </title>

</head>

<body data-scroll-animation="true">
    <div id="preloader">
        <div id="ctn-preloader" class="ctn-preloader">
            <div class="round_spinner">
                <div class="spinner"></div>
                <div class="text">
                    <img src="img/spinner_logo.png" alt="">
                    <h4><span>Doc</span>y</h4>
                </div>
            </div>
            <h2 class="head">Did You Know?</h2>
            <p></p>
        </div>
    </div>
    <div class="body_wrapper">
        <%- include('partials/header') %>

        <section class="doc_banner_area banner_creative1">
            <ul class="list-unstyled banner_shap_img">
                <li><img src="img/new/banner_shap1.png" alt=""></li>
                <li><img src="img/new/banner_shap4.png" alt=""></li>
                <li><img src="img/new/banner_shap3.png" alt=""></li>
                <li><img src="img/new/banner_shap2.png" alt=""></li>
                <li><img data-parallax='{"x": -180, "y": 80, "rotateY":2000}' src="img/new/plus1.png" alt=""></li>
                <li><img data-parallax='{"x": -50, "y": -160, "rotateZ":200}' src="img/new/plus2.png" alt=""></li>
                <li></li>
                <li></li>
                <li></li>
            </ul>
            <form action="#" id="cform" method="POST" enctype="multipart/form-data">
                <div class="container">
                    <div class="doc_banner_content">
                        <h2 class="wow fadeInUp"> Choose your file </h2>
                        <p class="wow fadeInUp" data-wow-delay="0.2s"> Select a file to start conversion </p>
                        <form action="#" class="header_search_form">
                            <div class="header_search_form_info">
                                <div class="form-group">
                                    <div class="d-flex mb-2 justify-content-center">
                                        <div class="btn-group dropdown">
                                            <button type="button" class="btn btn-primary btn-lg triggerbutton">
                                                <i class="icon icon_plus mr-1"></i>
                                                Upload File
                                            </button> 
                                            <input type="file" multiple="multiple" name="images" class="d-none main-input" accept="image/*">
                                        </div>
                                        <button 
                                            type="button" 
                                            class="btn btn-primary btn-lg mx-2 dropdown-toggle" 
                                            data-toggle="dropdown" 
                                        >
                                            <i class="icon icon_link mr-1"></i>
                                            Upload By URL
                                        </button> 
                                        <div class="dropdown-menu dropdown-menu-right">
                                            <div class="container" style="width:500px;">
                                                <div class="d-flex" style="gap:5px">
                                                    <input 
                                                        type="text" 
                                                        name="url" 
                                                        class="form-control" 
                                                        placeholder="paste a URL here to upload"
                                                    >
                                                    <button class="btn btn-success uploader-btn" >Upload</button>
                                                </div>
                                            </div>
                                        </div> 
                                    </div>
                                </div>
                            </div>
                        </form>

                    </div>
                    <div class="doc_banner_content uploaded">
                        <table class="table table-striped table-hover">
                            <tbody class="table-rows">
                            </tbody>
                        </table>
                        <button class="position-absolute btn bg-white" style="left:10px">Add more</button>
                        <button type="submit" class="position-absolute btn bg-white convert" style="right:10px">Convert</button>
                    </div>
                    
                </div>
            </form>

        </section>
        
        <%- include('partials/footer') %>
    </div>

    <!-- Back to top button -->
    <a id="back-to-top" title="Back to Top"></a>

    <!-- Optional JavaScript -->
    <!-- jQuery first, then Popper.js, then Bootstrap JS -->
    <script src="js/jquery-3.5.1.min.js"></script>
    <script src="assets/bootstrap/js/popper.min.js"></script>
    <script src="assets/bootstrap/js/bootstrap.min.js"></script>
    <script src="js/pre-loader.js"></script>
    <!-- <script src="assets/slick/slick.min.js"></script> -->
    <script src="js/jquery.parallax-scroll.js"></script>
    <script src="assets/niceselectpicker/jquery.nice-select.min.js"></script>
    <!-- <script src="assets/wow/wow.min.js"></script> -->
    <script src="assets/mcustomscrollbar/jquery.mCustomScrollbar.concat.min.js"></script>
    <script src="assets/magnify-pop/jquery.magnific-popup.min.js"></script>
    <script src="js/plugins.js"></script>
    <script src="https://unpkg.com/ionicons@5.4.0/dist/ionicons.js"></script>
    <script src="js/main.js"></script>

    <script>
        
        const wrapText = (text, maxLength) => {
            if (text?.length > maxLength) {
                let truncatedText = text.substring(0, maxLength) + '...';
                return truncatedText;
            }
            return text
        }

        let images = [];

        $(function(){

            $('.triggerbutton').click(function(){
                $('.main-input').trigger('click')
            })

            $('.main-input').on('change', function(e){
                
                $('.doc_banner_content .table-rows').children().remove();
                let files = e.target.files;
                [...files].forEach( (file,i) => {
                    images.push(file)
                });
                makePreview()

            });

        })

        let i = 0;

        function makePreview() {

            let length = $('.doc_banner_content .table-rows tr')?.length + 1;
            
            $('.doc_banner_content .table-rows').children().remove();

            for (let index = 0; index < images.length; index++) {
                const file = images[index];
                const extension = file.name.split('.')[1];
                var reader = new FileReader();
                reader.readAsDataURL(file);
                reader.onload = function() {
                    
                    let html = `<tr class="mt-2 w-100" data-index="${index}">\
                        <td style="width:35%">
                            <b class="fs-14 mb-1 heighted">${wrapText(file.name, 40)}</b>\
                            <input type="hidden" name="names=[]" value="${file.name}">
                        </td>
                        <td style="width:25%">
                            <div style="display:flex" class="dropdown">
                                <div class="avatar-sm bg-light heighted">\
                                    <span>Convert To</span>
                                </div>\
                                <button data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" class="mx-3 btn dropdown-toggle dropdown-toggle-split">
                                    <span data-name="${file.name}">...</span>
                                    <ul class="dropdown-menu" id="navbarSupportedContent">
                                        <li class="dropdown-item buttons">
                                            <div class="row">`;

                    for (const ext of ['jpg','png','webp','avif','tiff','svg']) {
                        if(ext!== extension) {
                            html += `<div class="card" data-index="${index}">
                                <a class="btn text-white bg-dark" >${ext.toUpperCase()}</a>
                            </div>`;
                        }
                    }
                                        
                    html += `</div></li>
                                </ul>
                            </div>
                        </td>
                        <td style="width:25%" class="action-${index}"></td>
                        <td style="width:15%">
                            <i class="icon_close text-danger" onclick="removeSpecificFile(${index})" style="font-size:1.8rem;cursor:pointer"></i>
                        </td>
                    </tr>`;
                    console.log(html)
                    $('.doc_banner_content .table-rows').append(html);

                    $('.buttons .card').on('click', function(e){
                        $('tr[data-index="'+ this.dataset.index +'"] td .dropdown-toggle span').text(this.innerText);
                    })
                    $('tfoot tr').css('display', $('tbody tr').length? 'flex':'none');

                }

                
            }
           

        }

        function removeSpecificFile(index) {
            // return console.log(index)
            const input = document.querySelector('input[type=file].d-none')
            images.splice(index,1)
            // delete images[index];
            const newFileList = Object.values(images)
            let dataTransfer = new DataTransfer();
            input.files=null
            input.value='';
            $('.doc_banner_content .table-rows').children().remove();
            newFileList.forEach(file => {
                if(typeof file==='object'){
                    dataTransfer.items.add(file)
                    var reader = new FileReader();
                    reader.readAsDataURL(file);
                    reader.onload = function() {
                        makePreview(reader.result, file.name, newFileList.indexOf(file));
                    }
                }
            });

            if(newFileList[0] && typeof newFileList[0]==='object'){
                input.files = dataTransfer.files;
            }

            $('tr[data-index="'+index+'"]').remove();
            event.preventDefault();

        }

        $('#cform').submit(function(e){
            e.preventDefault();
            const fd = new FormData();//$('#cform')[0]
            const meta = {};
            $('td .dropdown-toggle span').each(function(k,span) {
                meta[span.dataset.name]=span.innerText;
            });

            const route = images.length > 1? "convert-multiple":"bg/remove";
            fd.append('_meta', JSON.stringify(meta));
            // fd.append('images', images)
            images.forEach(f=> fd.append('images',f ));

            const extension = Object.values(meta)[0].toLowerCase()
            const filename = Object.keys(meta)[0].split(".")[0]

            $.ajax({
                url: "http://localhost:3100/" + route,
                type:"POST",
                processData:false,
                contentType:false,
                data:fd,
                xhrFields: {
                    responseType: 'blob' // 👈 important!
                },
                success:function (blob) {
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    if(route === 'convert-multiple') {
                        a.download = 'converted.zip';
                    } else {
                        a.download = filename+'-converted.'+extension;
                    }
                    document.body.appendChild(a);
                    a.click();
                    a.remove();
                },
                error: err=> console.log(err)
            });
        })

        const imageURLs = [];

        $('.uploader-btn').click( async function(e) {

            e.preventDefault();
            e.stopImmediatePropagation();
            e.stopPropagation();
            const url = $('input[name=url]').val();

            // https://upload.wikimedia.org/wikipedia/en/2/21/Web_of_Spider-Man_Vol_1_129-1.png
            let filename = url.split('/');
            filename = filename[filename.length-1];
            
            let blob;
            try {

                const res = await fetch(url);
                if (!res.ok) {
                    throw new Error(`HTTP error! Status: ${res.status}`);
                }
                blob = await res.blob();

            } catch (err) {
                console.error('Fetch or blob conversion failed:', err.message);
                // Handle error — show message, retry, fallback, etc.
                return alert("Something wrong with the url."+err.message)
            }

            const file = new File([blob], filename, {
                type: blob.type,
                lastModified: Date.now(),
            });
            imageURLs.push(file);
            images.push(file);

            console.log(Object.values(images))
            const newFileList = Object.values(images)
            let dataTransfer = new DataTransfer();
            const input = document.querySelector('input[name="images"]');
            input.files=null
            input.value='';
            if(newFileList[0] && typeof newFileList[0]==='object'){
                console.log('vyawastha to hai..', dataTransfer.files)
                input.files = dataTransfer.files;
            }

            makePreview()
        });

    </script>
</body>

</html>